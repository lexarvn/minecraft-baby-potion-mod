{
  "schemaVersion": 1,
  "id": "baby_potion",
  "version": "${version}",
  "name": "baby_potion",
  "description": "Adds a potion that temporarily reverts mobs to their baby form (or scales them down if they are not baby-capable).",
  "authors": [
    "LexarVN"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/baby_potion/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "lexarvn.baby_potion.BabyPotion"
    ]
  },
  "mixins": [ 
    "baby_potion.mixins.json",
    {
			"config": "baby_potion.client.mixins.json",
			"environment": "client"
		}
  ],
  "depends": {
    "fabricloader": ">=0.18.5",
    "minecraft": "~26.1.1",
    "java": ">=25",
    "fabric-api": "*"
  }
}